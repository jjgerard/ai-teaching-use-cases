ADMIN_PASSWORD=change-me
SESSION_SECRET=change-me-too-a-long-random-string
PORT=3000

# Email notifications on new submissions (optional — if any of these three
# are missing, notification emails are silently skipped, everything else
# still works).
# GMAIL_USER is the Gmail account that SENDS the notification. Generate an
# app password at https://myaccount.google.com/apppasswords (requires
# 2-Step Verification to be turned on for that account first).
GMAIL_USER=your-sending-account@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password
NOTIFY_EMAIL=where-you-want-notifications@example.com

# Git persistence for approved entries (optional — if either var is missing,
# git syncing is silently skipped and the app still works, it just relies
# entirely on the database/disk for approved entries). See README for how to
# create the token.
GITHUB_TOKEN=github_pat_xxxxxxxxxxxx
GITHUB_REPO=your-username/case-study-catalog
GITHUB_BRANCH=main
